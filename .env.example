# Cerberus Pro - Environment Configuration

# GENERAL
ENVIRONMENT=development
# "development", "staging", "production"

# SECURITY (CRITICAL)
# Generate a secure key with: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_secure_random_hex_string_32_bytes_minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# NETWORK
API_HOST=127.0.0.1
API_PORT=8011
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# FRONTEND (optional)
# If the frontend is opened from another machine, do NOT use 127.0.0.1.
# Example (backend host on LAN):
# VITE_API_URL=http://192.168.40.10:8011
# VITE_WS_URL=ws://192.168.40.10:8011

# RATE LIMITING
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# EXTERNAL TOOLS
CERBERUS_SQLMAP_PATH=../cerberus_engine/sqlmap.py

# PHASE 3 - CHAIN SANDBOX EXECUTION
CERBERUS_CHAIN_SANDBOX_MODE=auto
CERBERUS_CHAIN_SANDBOX_IMAGE=cerberus-chain-runner:latest
CERBERUS_CHAIN_SANDBOX_TIMEOUT_SEC=120
CERBERUS_CHAIN_SANDBOX_NETWORK=bridge
CERBERUS_CHAIN_SANDBOX_READ_ONLY=true

# DATA PROTECTION
ENCRYPTION_KEY=generate_this_with_fernet_key_generator
