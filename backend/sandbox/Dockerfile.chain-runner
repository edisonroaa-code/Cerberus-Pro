FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY backend/requirements_secure.txt /tmp/requirements_secure.txt
RUN pip install --upgrade pip \
    && pip install -r /tmp/requirements_secure.txt

# The workspace is mounted at runtime by the sandbox runner.
CMD ["python", "--version"]

